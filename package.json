{
  "name": "mobilesurvey",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DDI-compliant, mobile-first survey design & electronic-questionnaire authoring tool",
  "scripts": {
    "dev": "pnpm --filter @mobilesurvey/designer dev",
    "build": "pnpm --filter @mobilesurvey/designer build",
    "preview": "pnpm --filter @mobilesurvey/designer preview",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.48.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9"
}
